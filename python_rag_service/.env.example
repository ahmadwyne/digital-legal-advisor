# Digital Legal Advisor RAG Service -- Configuration
# Copy this file to .env and fill in your values.
# This file is safe to commit; .env is NOT.

# ── Backend selector ─────────────────────────────────────────────────────────
# groq   = Groq free API (recommended -- fast, professional quality)
# ollama = your fine-tuned model via Ollama (local, requires ollama serve)
# local  = your fine-tuned GGUF model via llama-cpp-python (requires AVX2 CPU)
BACKEND=groq

# ── Groq backend (BACKEND=groq) ───────────────────────────────────────────────
# Free key from console.groq.com (no credit card required)
GROQ_API_KEY=your_groq_api_key_here
# Available free models: llama-3.1-8b-instant  llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant

# ── Local GGUF backend (BACKEND=local) ────────────────────────────────────────
# Full path to your .gguf file (7.7 GB Q8 or 4.1 GB Q4_K_M)
GGUF_PATH=E:\mistral-legal-q8.gguf

# ── Vector store ──────────────────────────────────────────────────────────────
# Relative to this file (place vector_store_v2/ next to api_server.py)
VECTOR_STORE_DIR=vector_store_v2

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must match LLM_API_KEY in backend/.env
# Leave blank to disable auth (fine for local development)
SERVICE_API_KEY=demo-secret

# ── Network ───────────────────────────────────────────────────────────────────
SERVICE_PORT=8000
